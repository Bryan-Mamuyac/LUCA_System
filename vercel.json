{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html",   "use": "@vercel/static" },
    { "src": "*.css",    "use": "@vercel/static" },
    { "src": "*.js",     "use": "@vercel/static",
      "config": { "excludeFiles": "api/**" } },
    { "src": "*.png",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/",         "dest": "/login.html" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}